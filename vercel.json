{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/server.mjs": {
      "runtime": "@vercel/node@5.1.14",
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/|_build/|assets/|favicon\\.ico|favicon\\.png|robots\\.txt|sitemap\\.xml).*)", "destination": "/api/server" }
  ]
}
