{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/server.mjs": {
      "runtime": "@vercel/node@5.1.14",
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    { "source": "/__l5e/:path*", "destination": "https://bdd29baf-067a-47c5-b52e-ee9bf4354281.lovableproject.com/__l5e/:path*" },
    { "source": "/((?!api/|_build/|assets/|__l5e/|favicon\\.ico|favicon\\.png|robots\\.txt|sitemap\\.xml).*)", "destination": "/api/server" }
  ]
}
